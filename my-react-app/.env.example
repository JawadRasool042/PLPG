# ============================================
# PLPG Frontend Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# API Configuration
# ============================================
# Optional in local dev: when unset, the app uses "/api" and Vite proxies to
# Flask on http://127.0.0.1:5000 (see vite.config.ts). Set this if the API is
# on another host/port or you are not using `npm run dev`.
# VITE_API_BASE_URL=http://localhost:5000/api

# Optional: proxy target when using the default /api dev proxy (backend URL)
# VITE_PROXY_TARGET=http://127.0.0.1:5000

# Production API URL (required for production builds)
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# ============================================
# Admin Panel Configuration
# ============================================
# Admin login URL (optional, defaults to /admin/login)
VITE_ADMIN_LOGIN_URL=/admin/login

# JWT token storage keys (optional)
VITE_ADMIN_TOKEN_KEY=plpg_admin_access_token
VITE_ADMIN_REFRESH_TOKEN_KEY=plpg_admin_refresh_token
