# PLPG Backend Python - Environment Variables
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
# Set true only for local dev when JWT/SECRET placeholders are not configured yet
ALLOW_INSECURE_DEV_SECRETS=false
SECRET_KEY=replace-with-strong-random-secret-at-least-32-characters
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/plpg

# JWT Configuration
JWT_SECRET=replace-with-strong-random-jwt-secret-at-least-32-characters
JWT_EXPIRES_IN=30m
JWT_REFRESH_SECRET=replace-with-strong-random-jwt-refresh-secret-at-least-32-characters
JWT_REFRESH_EXPIRES_IN=7d

# Admin JWT (separate for extra security)
ADMIN_JWT_SECRET=replace-with-strong-random-admin-jwt-secret-at-least-32-characters
ADMIN_JWT_EXPIRE=24h
ADMIN_JWT_REFRESH_SECRET=replace-with-strong-random-admin-refresh-secret-at-least-32-characters
ADMIN_JWT_REFRESH_EXPIRE=7d

# Email — Gmail (default) uses smtp.gmail.com + App Password. For other hosts set EMAIL_SERVICE=smtp.
# Steps: Google Account → Security → 2-Step Verification → App passwords → generate for "Mail".
# Use the 16-character app password in EMAIL_PASSWORD (spaces are stripped automatically).
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
# Legacy alias also accepted by backend: EMAIL_PASS=your-app-password
EMAIL_FROM=PLPG Learning Platform <your-email@gmail.com>
# Optional overrides (defaults are correct for Gmail):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# EMAIL_USE_TLS=True
# Aliases: EMAIL_HOST, EMAIL_PORT
# If port 587 is blocked, try SMTP_PORT=465 (implicit SSL; set EMAIL_USE_TLS=false or omit for 465).
# If EHLO fails on Windows, set: SMTP_EHLO_HOSTNAME=your.pc.hostname
# Optional: verbose SMTP wire log in Flask / script console
# SMTP_DEBUG=true
#
# Non-Gmail SMTP:
# EMAIL_SERVICE=smtp
# SMTP_HOST=mail.example.com
# SMTP_PORT=587

# Email Token Settings
EMAIL_TOKEN_EXPIRY_HOURS=24
RESEND_COOLDOWN_MINUTES=5

# Local dev without Gmail: uncomment the next line (non-production only). Set false when real SMTP is configured.
# ALLOW_DEV_EMAIL_WITHOUT_SMTP=true
ALLOW_DEV_EMAIL_WITHOUT_SMTP=
# If SMTP is configured but fails in dev, uncomment to return verification URLs in API responses (non-production only):
# PLPG_FORCE_EMAIL_DEV_LINKS=true

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_AI_QUIZ_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_STRICT_QUIZ_MODEL=gpt-4o-mini
OPENAI_CHAT_MAX_TOKENS=600
OPENAI_CHAT_TEMPERATURE=0.7
OPENAI_QUIZ_TIMEOUT=8
OPENAI_QUIZ_MAX_TOKENS=1600
OPENAI_FALLBACK_TIMEOUT=5
OPENAI_FALLBACK_MAX_TOKENS=1000
# Learning path generation (large JSON — increase timeout if on slow networks)
OPENAI_PATH_TIMEOUT=120
OPENAI_PATH_CONNECT_TIMEOUT=15
OPENAI_PATH_RETRIES=2

# Quiz remediation — minimum score to continue without studying (default 70)
QUIZ_PASSING_SCORE=70
# Optional: override model for remediation lesson generation
# OPENAI_REMEDIATION_MODEL=gpt-4o-mini

# LLM Provider
LLM_PROVIDER=openai

# Frontend URL — verification links use this origin; production must match the site users open in the browser
FRONTEND_BASE_URL=http://localhost:5173
APP_DOMAIN=localhost

# Career salaries, courses, roadmap & jobs — all tailored for this market
# Roadmap includes Pakistan milestones (Rozee.pk, DigiSkills, freelancing, local IT)
CAREER_MARKET_REGION=Pakistan
